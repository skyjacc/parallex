// ============================================================
// PRX Store — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum OrderStatus {
  COMPLETED
  REVIEW
  REJECTED
}

enum TicketStatus {
  OPEN
  CLOSED
}

enum DetectionStatus {
  UNDETECTED
  TESTING
  UPDATING
}

enum CheatType {
  INTERNAL
  EXTERNAL
  SPOOFER
  SCRIPT
  ACCOUNT
  EXECUTOR
}

// ── User ─────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String   @unique
  email        String   @unique
  password     String
  image        String?
  prxBalance   Int      @default(0)
  role         Role     @default(USER)
  flagged      Boolean  @default(false)
  referralCode String?  @unique
  referredBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  transactions Transaction[]
  tickets      Ticket[]
  messages     Message[]
  reviews      Review[]
  referrals    Referral[]  @relation("Referrer")
  referred     Referral?   @relation("Referred")
  couponUses   CouponUse[]

  @@index([role])
  @@index([referralCode])
}

// ── Category ─────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  products Product[]

  @@index([slug])
}

// ── Product ──────────────────────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  name            String
  description     String
  imageUrl        String?
  pricePrx        Int
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cheatType       CheatType?
  detectionStatus DetectionStatus @default(UNDETECTED)
  osSupport       String          @default("Windows 10, 11")
  cpuSupport      String          @default("Intel, AMD")
  tags            Json            @default("[]")
  featured        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  stocks  Stock[]
  orders  Order[]
  reviews Review[]

  @@index([pricePrx])
  @@index([categoryId])
  @@index([detectionStatus])
}

// ── Stock ────────────────────────────────────────────────────

model Stock {
  id        String   @id @default(cuid())
  content   String
  isSold    Boolean  @default(false)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isSold])
}

// ── Order ────────────────────────────────────────────────────

model Order {
  id         String      @id @default(cuid())
  userId     String
  productId  String
  stockId    String      @unique
  costPrx    Int
  status     OrderStatus @default(COMPLETED)
  couponCode String?
  createdAt  DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  stock   Stock   @relation(fields: [stockId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([productId])
  @@index([status])
}

// ── Transaction ──────────────────────────────────────────────

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  amountPrx     Int
  moneymotionId String            @unique
  status        TransactionStatus @default(PENDING)
  type          TransactionType   @default(DEPOSIT)
  cardLast4     String?
  cardBrand     String?
  createdAt     DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ── Review ───────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String   @default("")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

// ── Referral ─────────────────────────────────────────────────

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String   @unique
  bonusPrx       Int      @default(50)
  createdAt      DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

// ── Coupon ───────────────────────────────────────────────────

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int?
  discountFixed   Int?
  maxUses         Int       @default(0)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  uses CouponUse[]

  @@index([code])
}

model CouponUse {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  usedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
}

// ── Ticket ───────────────────────────────────────────────────

model Ticket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([status])
}

// ── Message ──────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole Role
  content    String
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ── PaymentMethod ────────────────────────────────────────────

model PaymentMethod {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String   @default("")
  icon        String   @default("")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
